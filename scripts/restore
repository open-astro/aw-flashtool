#!/bin/bash
set -euo pipefail

# Stock Firmware Restore for iOptron iMate
# Replaces OpenAstro Linux with the stock rootfs backup created during install.
#
# !!! WORK IN PROGRESS — DO NOT USE !!!
# This script currently bricks the device on the eMMC backup-streaming step.
# Use iOptron's SD card recovery image to return to stock until this is fixed.
#
# The boot chain (U-Boot, kernel, DTBs) is never touched — only the root
# filesystem contents are swapped. The stock rootfs tarball is streamed
# directly from the host through SSH into tar on the device, so no large
# files need to be stored in tmpfs.
#
# Usage:
#   ./scripts/restore                # interactive (prompts for IP)
#   ./scripts/restore 192.168.1.129  # non-interactive

if [ "${RESTORE_I_KNOW_THIS_BRICKS:-}" != "yes" ]; then
    cat <<'EOF'
========================================
  scripts/restore — WORK IN PROGRESS
========================================

This script is not ready for general use. It currently bricks the device
during the rootfs replacement step. Use iOptron's SD card recovery image
to return to stock instead.

If you are actively debugging the script and want to run it anyway:
  RESTORE_I_KNOW_THIS_BRICKS=yes ./scripts/restore [ip]

EOF
    exit 1
fi

REPODIR="$(cd "$(dirname "$0")/.." && pwd)"
IMAGES_DIR="$REPODIR/images"

ASTRO_USER="astro"
ASTRO_PASS="astro"
STOCK_USER="imate"
STOCK_PASS="imate"

# --- Helpers ---

prompt_continue() {
    echo ""
    read -rp "$1 [Y/n] " answer
    case "$answer" in
        [nN]*) echo "Aborted."; exit 0 ;;
    esac
}

SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

ssh_run() {
    sshpass -p "$ASTRO_PASS" ssh $SSH_OPTS \
        -o ConnectTimeout=10 \
        -o ServerAliveInterval=15 \
        "$ASTRO_USER@$IMATE_IP" "$1"
}

scp_to() {
    sshpass -p "$ASTRO_PASS" scp $SSH_OPTS \
        "$1" "$ASTRO_USER@$IMATE_IP:$2"
}

# --- Banner ---

echo ""
echo "========================================"
echo "  Stock Firmware Restore for iMate"
echo "========================================"
echo ""
echo "This script will:"
echo "  1. Connect to your iMate running OpenAstro Linux"
echo "  2. Stream the stock rootfs backup to the device"
echo "  3. Replace the OS with stock firmware"
echo "  4. Reboot into stock firmware"
echo ""
echo "The boot chain is never modified."
echo ""

# --- Preflight ---

MISSING=""
if ! command -v sshpass >/dev/null 2>&1; then
    MISSING="$MISSING  sshpass (sudo apt install sshpass)\n"
fi
if ! command -v ssh >/dev/null 2>&1; then
    MISSING="$MISSING  ssh (sudo apt install openssh-client)\n"
fi
if ! command -v pv >/dev/null 2>&1; then
    MISSING="$MISSING  pv (sudo apt install pv)\n"
fi

if [ -n "$MISSING" ]; then
    echo "Missing prerequisites:"
    echo -e "$MISSING"
    exit 1
fi

# --- Find stock rootfs backup ---

STOCK_ROOTFS="$IMAGES_DIR/imate-stock-rootfs.tar.gz"

if [ ! -f "$STOCK_ROOTFS" ]; then
    echo "ERROR: Stock rootfs backup not found."
    echo ""
    echo "Expected: $STOCK_ROOTFS"
    echo ""
    echo "This file is created automatically when you run ./scripts/install."
    echo "You must install OpenAstro at least once before you can restore."
    exit 1
fi

STOCK_SIZE=$(du -h "$STOCK_ROOTFS" | cut -f1)
STOCK_SIZE_BYTES=$(stat -c%s "$STOCK_ROOTFS")
echo "Stock rootfs: $(basename "$STOCK_ROOTFS") ($STOCK_SIZE)"

# --- Find iMate ---

IMATE_IP="${1:-}"

if [ -z "$IMATE_IP" ]; then
    echo ""
    echo "Scanning for iMate on the network..."

    SSH_TEST="sshpass -p $ASTRO_PASS ssh $SSH_OPTS -o ConnectTimeout=3"

    # Try known hostnames first
    for host in astro astro.local iMate iMate.local imate imate.local; do
        if $SSH_TEST "$ASTRO_USER@$host" "echo ok" >/dev/null 2>&1; then
            IMATE_IP="$host"
            break
        fi
    done

    # Try ARP/neighbor scan for hosts responding on port 22
    if [ -z "$IMATE_IP" ]; then
        echo "  Hostname lookup failed, scanning local subnet..."
        SUBNET=$(ip -4 route show default | awk '{print $3}' | sed 's/\.[0-9]*$/./')
        if [ -n "$SUBNET" ]; then
            for i in $(seq 1 254); do
                IP="${SUBNET}${i}"
                if $SSH_TEST "$ASTRO_USER@$IP" "echo ok" >/dev/null 2>&1; then
                    IMATE_IP="$IP"
                    break
                fi
            done &
            SCAN_PID=$!

            # Parallel: ping sweep to populate ARP cache, then test responders
            for i in $(seq 1 254); do
                ping -c 1 -W 1 "${SUBNET}${i}" >/dev/null 2>&1 &
            done
            wait 2>/dev/null

            # Check ARP table for known iMate MAC prefixes or hostnames
            if [ -z "$IMATE_IP" ]; then
                for IP in $(arp -n 2>/dev/null | awk '/ether/{print $1}'); do
                    if $SSH_TEST "$ASTRO_USER@$IP" "echo ok" >/dev/null 2>&1; then
                        IMATE_IP="$IP"
                        break
                    fi
                done
            fi

            kill "$SCAN_PID" 2>/dev/null || true
            wait "$SCAN_PID" 2>/dev/null || true
        fi
    fi

    if [ -n "$IMATE_IP" ]; then
        echo "  Found iMate at $IMATE_IP"
    else
        echo "  Could not auto-detect iMate on the network."
        read -rp "Enter iMate IP address: " IMATE_IP
        if [ -z "$IMATE_IP" ]; then
            echo "ERROR: No IP address provided."
            exit 1
        fi
    fi
fi

# --- Connect ---

echo ""
echo "Connecting to $ASTRO_USER@$IMATE_IP..."

if ! ssh_run "echo ok" >/dev/null 2>&1; then
    echo "ERROR: Cannot connect to $ASTRO_USER@$IMATE_IP via SSH."
    echo ""
    echo "Check that:"
    echo "  - The iMate is powered on and running OpenAstro Linux"
    echo "  - It is connected to your network"
    echo "  - The IP address is correct"
    echo "  - Credentials: $ASTRO_USER / $ASTRO_PASS"
    exit 1
fi

echo "Connected."

echo ""
echo "This will erase OpenAstro Linux and restore stock firmware."
echo ""
echo "  Image:   $(basename "$STOCK_ROOTFS") ($STOCK_SIZE)"
echo "  Target:  $ASTRO_USER@$IMATE_IP"
echo ""

prompt_continue "Restore stock firmware?"

# ============================================================
# Step 1: Prepare device
# ============================================================

echo ""
echo "========================================"
echo "  Step 1/3 — Prepare Device"
echo "========================================"
echo ""

echo "Ensuring filesystem is read-write..."
sshpass -p "$ASTRO_PASS" ssh $SSH_OPTS \
    -o ConnectTimeout=10 \
    "$ASTRO_USER@$IMATE_IP" \
    "echo '$ASTRO_PASS' | sudo -S mount -o remount,rw /dev/mmcblk2p1 / 2>/dev/null || true" 2>/dev/null || true
echo "  Done."

echo "Configuring passwordless sudo..."
sshpass -p "$ASTRO_PASS" ssh $SSH_OPTS \
    -o ConnectTimeout=10 \
    "$ASTRO_USER@$IMATE_IP" \
    "echo '$ASTRO_PASS' | sudo -S bash -c \"echo '$ASTRO_USER ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/$ASTRO_USER && chmod 440 /etc/sudoers.d/$ASTRO_USER\"" 2>/dev/null || true
echo "  Done."

echo "Cleaning up /tmp..."
ssh_run "sudo rm -rf /tmp/* 2>/dev/null || true" || true
echo "  Done."

echo "Stopping non-essential services..."
# Do NOT stop NetworkManager (manages ethernet, would drop our SSH) or
# ssh.socket (would block subsequent connections). wpa_supplicant only
# manages WiFi so it's safe.
ssh_run "sudo systemctl stop wpa_supplicant bluetooth avahi-daemon cron 2>/dev/null || true" || true
echo "  Done."

echo "Reading root partition UUID..."
ROOT_UUID=$(ssh_run "sudo blkid -s UUID -o value /dev/mmcblk2p1")
echo "  Root UUID: $ROOT_UUID"

# ============================================================
# Step 2: Restore stock firmware
# ============================================================

echo ""
echo "========================================"
echo "  Step 2/3 — Restore Stock Firmware"
echo "========================================"
echo ""
echo "This will erase OpenAstro Linux and restore stock firmware."
echo "The stock rootfs is streamed directly — nothing stored on the device."
echo "DO NOT power off the iMate during this process!"
echo ""

prompt_continue "Proceed with restore?"

echo "Streaming stock rootfs and replacing OS..."
echo "(The SSH connection will drop — this is expected)"
echo ""

pv -s "$STOCK_SIZE_BYTES" "$STOCK_ROOTFS" | \
    sshpass -p "$ASTRO_PASS" ssh $SSH_OPTS \
        -o ConnectTimeout=10 -o ServerAliveInterval=15 \
        "$ASTRO_USER@$IMATE_IP" \
        "sudo bash -c '
            set -e
            rm -rf /etc/update-motd.d
            tar xzf - -C /
            sync
            reboot
        '" || true

echo "Waiting for iMate to reboot..."
echo ""

# Wait for the device to go down
sleep 10 || true

# Wait for it to come back up with stock credentials
STOCK_SSH="sshpass -p $STOCK_PASS ssh $SSH_OPTS -o ConnectTimeout=5"
RETRIES=0
MAX_RETRIES=36  # 3 minutes

while ! $STOCK_SSH "$STOCK_USER@$IMATE_IP" "echo ok" >/dev/null 2>&1; do
    RETRIES=$((RETRIES + 1))
    if [ "$RETRIES" -ge "$MAX_RETRIES" ]; then
        echo ""
        echo "Cannot connect to $STOCK_USER@$IMATE_IP after 3 minutes."
        echo ""
        echo "The device may still be booting (stock firmware takes longer)."
        echo "Try manually:  ssh $STOCK_USER@$IMATE_IP"
        exit 0
    fi
    printf "  Waiting... (%ds)\r" "$((RETRIES * 5))"
    sleep 5
done

# ============================================================
# Step 3: Verify
# ============================================================

echo ""
echo ""
echo "========================================"
echo "  Step 3/3 — Verify"
echo "========================================"
echo ""
echo "Connected to stock firmware!"
echo ""

$STOCK_SSH "$STOCK_USER@$IMATE_IP" "\
    echo \"  Hostname: \$(hostname)\"; \
    echo \"  Kernel:   \$(uname -r)\"; \
    echo \"  Uptime:   \$(uptime -p)\""

echo ""
echo "========================================"
echo "  Stock firmware restored successfully!"
echo "========================================"
echo ""
echo "  User:      imate"
echo "  Password:  imate"
echo "  SSH:       ssh imate@$IMATE_IP"
echo ""
