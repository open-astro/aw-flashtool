#!/bin/bash
set -euo pipefail

# OpenAstro Linux Installer for iOptron iMate
# Replaces the stock OS with Debian Trixie over SSH.
#
# The stock boot chain (U-Boot, kernel, DTBs) is preserved — only the
# root filesystem contents are replaced. Stock firmware can be restored
# at any time using iOptron's SD card recovery image.
#
# Usage:
#   ./scripts/install                # interactive (prompts for IP)
#   ./scripts/install 192.168.1.129  # non-interactive

REPODIR="$(cd "$(dirname "$0")/.." && pwd)"
IMAGES_DIR="$REPODIR/images"
RELEASE_URL="https://github.com/open-astro/aw-flashtool/releases/download/v1.0/astrolinux-trixie-h6.tar.gz"

STOCK_USER="imate"
STOCK_PASS="imate"
NEW_USER="astro"
NEW_PASS="astro"

# --- Helpers ---

prompt_continue() {
    echo ""
    read -rp "$1 [Y/n] " answer
    case "$answer" in
        [nN]*) echo "Aborted."; exit 0 ;;
    esac
}

SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

ssh_run() {
    sshpass -p "$STOCK_PASS" ssh $SSH_OPTS \
        -o ConnectTimeout=10 \
        -o ServerAliveInterval=15 \
        "$STOCK_USER@$IMATE_IP" "$1"
}

ssh_run_sudo() {
    sshpass -p "$STOCK_PASS" ssh $SSH_OPTS \
        -o ConnectTimeout=10 \
        -o ServerAliveInterval=15 \
        "$STOCK_USER@$IMATE_IP" "echo '$STOCK_PASS' | sudo -S bash -c $(printf '%q' "$1")"
}

scp_to() {
    sshpass -p "$STOCK_PASS" scp $SSH_OPTS \
        "$1" "$STOCK_USER@$IMATE_IP:$2"
}

scp_from() {
    sshpass -p "$STOCK_PASS" scp $SSH_OPTS \
        "$STOCK_USER@$IMATE_IP:$1" "$2"
}

# --- Banner ---

echo ""
echo "========================================"
echo "  OpenAstro Linux Installer for iMate"
echo "========================================"
echo ""
echo "This script will:"
echo "  1. Connect to your iMate via SSH"
echo "  2. Preserve the stock kernel and firmware"
echo "  3. Replace the OS with Debian 13 (Trixie)"
echo "  4. Reboot into OpenAstro Linux"
echo ""
echo "The stock boot chain is never modified."
echo "To restore stock firmware, use iOptron's SD card recovery image."
echo ""

# --- Preflight ---

MISSING=""
if ! command -v sshpass >/dev/null 2>&1; then
    MISSING="$MISSING  sshpass (sudo apt install sshpass)\n"
fi
if ! command -v ssh >/dev/null 2>&1; then
    MISSING="$MISSING  ssh (sudo apt install openssh-client)\n"
fi
if ! command -v wget >/dev/null 2>&1 && ! command -v curl >/dev/null 2>&1; then
    MISSING="$MISSING  wget or curl (sudo apt install wget)\n"
fi
if ! command -v pv >/dev/null 2>&1; then
    MISSING="$MISSING  pv (sudo apt install pv)\n"
fi

if [ -n "$MISSING" ]; then
    echo "Missing prerequisites:"
    echo -e "$MISSING"
    exit 1
fi

# --- Find iMate ---

IMATE_IP="${1:-}"

if [ -z "$IMATE_IP" ]; then
    echo "Scanning for iMate on the network..."

    SSH_TEST="sshpass -p $STOCK_PASS ssh $SSH_OPTS -o ConnectTimeout=3"

    # Try known hostnames first
    for host in iMate iMate.local imate imate.local; do
        if $SSH_TEST "$STOCK_USER@$host" "echo ok" >/dev/null 2>&1; then
            IMATE_IP="$host"
            break
        fi
    done

    # Try ARP/neighbor scan for hosts responding on port 22
    if [ -z "$IMATE_IP" ]; then
        echo "  Hostname lookup failed, scanning local subnet..."
        SUBNET=$(ip -4 route show default | awk '{print $3}' | sed 's/\.[0-9]*$/./')
        if [ -n "$SUBNET" ]; then
            for i in $(seq 1 254); do
                IP="${SUBNET}${i}"
                if $SSH_TEST "$STOCK_USER@$IP" "echo ok" >/dev/null 2>&1; then
                    IMATE_IP="$IP"
                    break
                fi
            done &
            SCAN_PID=$!

            # Parallel: ping sweep to populate ARP cache, then test responders
            for i in $(seq 1 254); do
                ping -c 1 -W 1 "${SUBNET}${i}" >/dev/null 2>&1 &
            done
            wait 2>/dev/null

            # Check ARP table for known iMate MAC prefixes or hostnames
            if [ -z "$IMATE_IP" ]; then
                for IP in $(arp -n 2>/dev/null | awk '/ether/{print $1}'); do
                    if $SSH_TEST "$STOCK_USER@$IP" "echo ok" >/dev/null 2>&1; then
                        IMATE_IP="$IP"
                        break
                    fi
                done
            fi

            kill "$SCAN_PID" 2>/dev/null || true
            wait "$SCAN_PID" 2>/dev/null || true
        fi
    fi

    if [ -n "$IMATE_IP" ]; then
        echo "  Found iMate at $IMATE_IP"
    else
        echo "  Could not auto-detect iMate on the network."
        read -rp "Enter iMate IP address: " IMATE_IP
        if [ -z "$IMATE_IP" ]; then
            echo "ERROR: No IP address provided."
            exit 1
        fi
    fi
fi

# Resolve hostname to IP so the post-install wait loop doesn't depend on
# mDNS — the device's hostname changes from iMate to astro after install,
# so the original hostname stops resolving.
if ! [[ "$IMATE_IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    RESOLVED=$(getent ahostsv4 "$IMATE_IP" 2>/dev/null | awk '{print $1; exit}')
    if [ -n "$RESOLVED" ]; then
        echo "  Resolved $IMATE_IP -> $RESOLVED"
        IMATE_IP="$RESOLVED"
    fi
fi

# --- Connect ---

echo "Connecting to $STOCK_USER@$IMATE_IP..."

if ! ssh_run "echo ok" >/dev/null 2>&1; then
    echo "ERROR: Cannot connect to $STOCK_USER@$IMATE_IP via SSH."
    echo ""
    echo "Check that:"
    echo "  - The iMate is powered on"
    echo "  - It is connected to your network via ethernet"
    echo "  - The IP address is correct"
    exit 1
fi

echo "Connected."

# Verify this is an iMate (OrangePi 3 LTS / Allwinner H6)
BOARD=$(ssh_run "cat /proc/device-tree/compatible 2>/dev/null | tr '\0' '\n' | head -1")
if [[ "$BOARD" != *"orangepi-3"* ]]; then
    echo ""
    echo "WARNING: This device does not appear to be an iOptron iMate."
    echo "  Detected: $BOARD"
    prompt_continue "Continue anyway?"
fi

prompt_continue "Ready to install OpenAstro Linux?"

# ============================================================
# Step 1: Prepare device
# ============================================================

echo ""
echo "========================================"
echo "  Step 1/4 — Prepare Device"
echo "========================================"
echo ""

echo "Ensuring filesystem is read-write..."
ssh_run "sudo mount -o remount,rw /dev/mmcblk2p1 / 2>/dev/null || true" || true
echo "  Done."

echo "Configuring passwordless sudo..."
ssh_run_sudo "echo '$STOCK_USER ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/$STOCK_USER && chmod 440 /etc/sudoers.d/$STOCK_USER" 2>/dev/null || true
echo "  Done."

echo "Cleaning up previous run..."
ssh_run "sudo rm -f /tmp/stock-preserve.tar.gz 2>/dev/null || true" || true
echo "  Done."

echo "Stopping non-essential services..."
ssh_run "sudo systemctl stop hostapd dnsmasq lightdm nxserver cups bluetooth chrony smartd strongswan xl2tpd 2>/dev/null || true" || true
echo "  Done."

# ============================================================
# Step 2: Preserve stock files
# ============================================================

echo ""
echo "========================================"
echo "  Step 2/4 — Preserve Stock Files"
echo "========================================"
echo ""
echo "Saving kernel, modules, firmware, and hardware tools..."

ssh_run "sudo tar czf /tmp/stock-preserve.tar.gz \
    -C / \
    boot \
    lib/modules \
    lib/firmware/wcnmodem.bin \
    lib/firmware/wifi_2355b001_1ant.ini \
    usr/local/bin/gpio \
    usr/local/bin/watchdog_test \
    usr/local/lib/libwiringPi.so.2.46 \
    usr/local/lib/libwiringPiDev.so.2.46 \
    usr/local/lib/libftd2xx.so.1.4.27 \
    usr/local/lib/libftd2xx.a \
    usr/local/include/ftd2xx.h \
    usr/local/include/WinTypes.h \
    2>/dev/null || true"

PRESERVE_SIZE=$(ssh_run "du -h /tmp/stock-preserve.tar.gz | cut -f1")
echo "  Preserved $PRESERVE_SIZE of stock files."

# Get the real root partition UUID — needed to write a correct fstab after replacement
ROOT_UUID=$(ssh_run "sudo blkid -s UUID -o value /dev/mmcblk2p1")
echo "  Root UUID: $ROOT_UUID"

# ============================================================
# Step 3: Download rootfs
# ============================================================

echo ""
echo "========================================"
echo "  Step 3/4 — Download OpenAstro Linux"
echo "========================================"
echo ""

ROOTFS_LOCAL=""
for f in "$IMAGES_DIR"/astrolinux-trixie-h6.tar.gz "$IMAGES_DIR"/astrolinux-trixie-h6.tar.xz; do
    [ -f "$f" ] && ROOTFS_LOCAL="$f" && break
done

if [ -z "$ROOTFS_LOCAL" ]; then
    echo "No local image found, downloading..."
    echo "  $RELEASE_URL"
    echo ""
    mkdir -p "$IMAGES_DIR"
    ROOTFS_LOCAL="$IMAGES_DIR/astrolinux-trixie-h6.tar.gz"
    if command -v wget >/dev/null 2>&1; then
        wget -O "$ROOTFS_LOCAL" "$RELEASE_URL" || { rm -f "$ROOTFS_LOCAL"; echo "ERROR: Download failed."; exit 1; }
    else
        curl -L -o "$ROOTFS_LOCAL" "$RELEASE_URL" || { rm -f "$ROOTFS_LOCAL"; echo "ERROR: Download failed."; exit 1; }
    fi
fi

SIZE=$(du -h "$ROOTFS_LOCAL" | cut -f1)
SIZE_BYTES=$(stat -c%s "$ROOTFS_LOCAL")
echo "Using image: $(basename "$ROOTFS_LOCAL") ($SIZE)"

# Verify the preserve tarball
ssh_run "tar tzf /tmp/stock-preserve.tar.gz >/dev/null" || {
    echo "ERROR: Stock preserve tarball is corrupt."
    exit 1
}
echo "  OK."

# ============================================================
# Step 4: Replace OS
# ============================================================

echo ""
echo "========================================"
echo "  Step 4/4 — Install OpenAstro Linux"
echo "========================================"
echo ""
echo "This will erase the current OS and install Debian Trixie."
echo "DO NOT power off the iMate during this process!"
echo ""
echo "If something goes wrong, restore using iOptron's SD card recovery image."
echo ""

prompt_continue "Proceed with installation?"

echo "Streaming rootfs and replacing OS..."
echo "(The SSH connection will drop — this is expected)"
echo ""

pv -s "$SIZE_BYTES" "$ROOTFS_LOCAL" | \
    sshpass -p "$STOCK_PASS" ssh $SSH_OPTS \
        -o ConnectTimeout=10 -o ServerAliveInterval=15 \
        "$STOCK_USER@$IMATE_IP" \
        "sudo bash -c '
            set -e
            rm -rf /etc/update-motd.d
            tar xzf - -C /
            tar xzf /tmp/stock-preserve.tar.gz -C /
            cd /usr/local/lib
            ln -sf libwiringPi.so.2.46 libwiringPi.so
            ln -sf libwiringPiDev.so.2.46 libwiringPiDev.so
            ln -sf libftd2xx.so.1.4.27 libftd2xx.so
            echo \"UUID=$ROOT_UUID / ext4 defaults,noatime 0 1\" > /etc/fstab
            echo \"tmpfs /tmp tmpfs defaults 0 0\" >> /etc/fstab
            sync
            reboot
        '" || true

echo "Waiting for iMate to reboot..."
echo ""

# Wait for the device to go down
sleep 10 || true

# Wait for it to come back up with new credentials
NEW_SSH="sshpass -p $NEW_PASS ssh $SSH_OPTS -o ConnectTimeout=5"
RETRIES=0
MAX_RETRIES=36  # 3 minutes

while ! $NEW_SSH "$NEW_USER@$IMATE_IP" "echo ok" >/dev/null 2>&1; do
    RETRIES=$((RETRIES + 1))
    if [ "$RETRIES" -ge "$MAX_RETRIES" ]; then
        echo ""
        echo "ERROR: Cannot connect to $NEW_USER@$IMATE_IP after 3 minutes."
        echo ""
        echo "The device may still be booting. Try manually:"
        echo "  ssh $NEW_USER@$IMATE_IP"
        echo ""
        echo "If the device won't boot, restore using iOptron's SD card image."
        exit 1
    fi
    printf "  Waiting... (%ds)\r" "$((RETRIES * 5))"
    sleep 5
done

echo ""
echo "Connected to OpenAstro Linux!"
echo ""

# Show system info
$NEW_SSH "$NEW_USER@$IMATE_IP" "\
    echo \"  Hostname: \$(hostname)\"; \
    echo \"  OS:       \$(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '\"')\"; \
    echo \"  Kernel:   \$(uname -r)\"; \
    echo \"  Uptime:   \$(uptime -p)\""

echo ""
echo "========================================"
echo "  OpenAstro Linux installed successfully!"
echo "========================================"
echo ""
echo "  Hostname:  astro"
echo "  User:      astro"
echo "  Password:  astro"
echo "  SSH:       ssh astro@$IMATE_IP"
echo ""
echo "  First steps:"
echo "    passwd                              # change default password"
echo ""
echo "  WiFi (station mode — connect to your network):"
echo "    nmcli dev wifi list"
echo "    nmcli dev wifi connect <SSID> password <pass>"
echo ""
echo "  WiFi (AP mode — create a hotspot):"
echo "    nmcli device wifi hotspot ssid astro password <pass>"
echo ""
echo "  DC power ports:"
echo "    gpio write 2 1    # DC1 on"
echo "    gpio write 2 0    # DC1 off"
echo "    gpio write 6 1    # DC2 on"
echo "    gpio write 6 0    # DC2 off"
echo ""
echo "  To restore stock firmware:"
echo "    Use iOptron's SD card recovery image."
echo ""
